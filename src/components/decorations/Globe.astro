---
// Rotating concentric globe used on the hero slide.
---
<div class="globe-container rotating">
  <svg viewBox="0 0 400 400" fill="none">
    <circle cx="200" cy="200" r="180" stroke="var(--teal)" stroke-width="0.5" opacity="0.3"/>
    <circle cx="200" cy="200" r="140" stroke="var(--teal)" stroke-width="0.5" opacity="0.2"/>
    <circle cx="200" cy="200" r="100" stroke="var(--teal)" stroke-width="0.5" opacity="0.15"/>
    <ellipse cx="200" cy="200" rx="80" ry="180" stroke="var(--teal)" stroke-width="0.5" opacity="0.2"/>
    <ellipse cx="200" cy="200" rx="40" ry="180" stroke="var(--teal)" stroke-width="0.5" opacity="0.15"/>
    <line x1="20" y1="150" x2="380" y2="150" stroke="var(--teal)" stroke-width="0.5" opacity="0.1"/>
    <line x1="20" y1="200" x2="380" y2="200" stroke="var(--teal)" stroke-width="0.5" opacity="0.15"/>
    <line x1="20" y1="250" x2="380" y2="250" stroke="var(--teal)" stroke-width="0.5" opacity="0.1"/>
  </svg>
</div>
