---
// Animated 2024 → 2030 growth curve drawn on slide entry.
---
<svg viewBox="0 0 800 220" width="100%"
     style="margin:32px auto 0;max-width:880px;opacity:0;overflow:hidden"
     class="reveal-on-active growth-svg" data-delay="500">
  <defs>
    <linearGradient id="grow-fill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#CCFF00" stop-opacity="0.45"/>
      <stop offset="55%" stop-color="#CCFF00" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#CCFF00" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="grow-line" x1="0" y1="1" x2="1" y2="0">
      <stop offset="0%" stop-color="#1a8a9a"/>
      <stop offset="55%" stop-color="#7be000"/>
      <stop offset="100%" stop-color="#CCFF00"/>
    </linearGradient>
    <filter id="grow-glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3.5" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <clipPath id="chart-clip">
      <rect x="-2" y="-2" width="804" height="224"/>
    </clipPath>
  </defs>

  <line x1="0" y1="60"  x2="800" y2="60"  stroke="rgba(122,138,158,0.16)" stroke-dasharray="3 7"/>
  <line x1="0" y1="120" x2="800" y2="120" stroke="rgba(122,138,158,0.13)" stroke-dasharray="3 7"/>
  <line x1="0" y1="180" x2="800" y2="180" stroke="rgba(122,138,158,0.10)" stroke-dasharray="3 7"/>

  <g clip-path="url(#chart-clip)">
    <path d="M0 220 L0 200 C140 199 240 195 340 186 C440 176 510 160 560 132 C605 108 645 70 680 30 C705 -5 725 -60 745 -160 L800 -160 L800 220 Z"
          fill="url(#grow-fill)" class="growth-fill"/>

    <path d="M0 200 C140 199 240 195 340 186 C440 176 510 160 560 132 C605 108 645 70 680 30 C705 -5 725 -60 745 -160"
          stroke="url(#grow-line)" stroke-width="3" fill="none"
          stroke-linecap="round" stroke-linejoin="round"
          pathLength="1200"
          stroke-dasharray="1200" stroke-dashoffset="1200"
          filter="url(#grow-glow)"
          class="growth-line"/>
  </g>

  <circle cx="20"  cy="199" r="3"  fill="#7a8a9e" class="growth-dot" style="--d:0.6s"/>
  <circle cx="200" cy="192" r="3"  fill="#7a8a9e" class="growth-dot" style="--d:1.1s"/>
  <circle cx="420" cy="168" r="4"  fill="#CCFF00" class="growth-dot" style="--d:1.6s"/>
  <circle cx="680" cy="30"  r="6"  fill="#CCFF00" class="growth-dot growth-dot-end" style="--d:2.0s"/>

  <text x="20"  y="216" fill="#7a8a9e" font-size="11" font-family="Space Mono">2024</text>
  <text x="200" y="216" fill="#7a8a9e" font-size="11" font-family="Space Mono">2026</text>
  <text x="420" y="216" fill="#7a8a9e" font-size="11" font-family="Space Mono">2028</text>
  <text x="680" y="216" fill="#CCFF00" font-size="12" font-family="Space Mono" font-weight="700">2030</text>
</svg>

<style>
  .growth-svg{display:block}

  .growth-fill{
    opacity:0;
    transition:opacity 1.4s ease 1.2s;
  }
  .active .growth-fill{opacity:1}

  .growth-dot{
    opacity:0;transform-origin:center;
    transition:opacity 0.4s ease var(--d), transform 0.4s ease var(--d);
    transform:scale(0.4);
  }
  .active .growth-dot{opacity:1;transform:scale(1)}
  .growth-dot-end{filter:drop-shadow(0 0 10px rgba(204,255,0,0.95))}
</style>
