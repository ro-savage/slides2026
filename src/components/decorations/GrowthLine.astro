---
// Animated 2024 → 2030 growth curve drawn on slide entry.
---
<svg viewBox="0 0 800 230" width="100%"
     style="margin:32px auto 0;max-width:880px;overflow:visible"
     class="growth-svg">
  <defs>
    <linearGradient id="grow-fill" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#CCFF00" stop-opacity="0.45"/>
      <stop offset="55%" stop-color="#CCFF00" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#CCFF00" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="grow-line" x1="0" y1="1" x2="1" y2="0">
      <stop offset="0%" stop-color="#1a8a9a"/>
      <stop offset="55%" stop-color="#7be000"/>
      <stop offset="100%" stop-color="#CCFF00"/>
    </linearGradient>
    <filter id="grow-glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3.5" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    <clipPath id="chart-clip">
      <rect x="-2" y="-2" width="804" height="234"/>
    </clipPath>
  </defs>

  <line x1="0" y1="60"  x2="800" y2="60"  stroke="rgba(122,138,158,0.16)" stroke-dasharray="3 7"/>
  <line x1="0" y1="120" x2="800" y2="120" stroke="rgba(122,138,158,0.13)" stroke-dasharray="3 7"/>
  <line x1="0" y1="180" x2="800" y2="180" stroke="rgba(122,138,158,0.10)" stroke-dasharray="3 7"/>

  <g clip-path="url(#chart-clip)">
    <path d="M0 220 L0 200 C 180 199 320 192 460 178 C 580 165 660 130 720 80 C 750 50 770 30 778 22 L 800 0 L 800 220 Z"
          fill="url(#grow-fill)" class="growth-fill"/>

    <path d="M0 200 C 180 199 320 192 460 178 C 580 165 660 130 720 80 C 750 50 770 30 778 22"
          stroke="url(#grow-line)" stroke-width="3" fill="none"
          stroke-linecap="round" stroke-linejoin="round"
          pathLength="1200"
          stroke-dasharray="1200" stroke-dashoffset="1200"
          filter="url(#grow-glow)"
          class="growth-line"/>
  </g>

  <text x="20"  y="222" fill="#e8edf3" font-size="11" font-family="Space Mono">2024</text>
  <text x="270" y="222" fill="#e8edf3" font-size="11" font-family="Space Mono">2026</text>
  <text x="520" y="222" fill="#e8edf3" font-size="11" font-family="Space Mono">2028</text>
  <text x="800" y="222" text-anchor="end" fill="#CCFF00" font-size="12" font-family="Space Mono" font-weight="700">2030</text>
</svg>

<style>
  .growth-svg{display:block;opacity:0}
  :global(.active) .growth-svg{animation: growth-fade-in 0.6s ease 0.8s forwards}
  @keyframes growth-fade-in { to { opacity: 1 } }

  .growth-line{stroke-dasharray:1200;stroke-dashoffset:1200}
  :global(.active) .growth-line{
    animation: growth-line-draw 2.6s cubic-bezier(.22,1,.36,1) 1.4s forwards;
  }
  @keyframes growth-line-draw { to { stroke-dashoffset: 0 } }

  .growth-fill{opacity:0}
  :global(.active) .growth-fill{animation: growth-fill-in 1.4s ease 3.6s forwards}
  @keyframes growth-fill-in { to { opacity: 1 } }
</style>
