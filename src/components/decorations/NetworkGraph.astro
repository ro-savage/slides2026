    <circle cx="60" cy="150" r="8" fill="rgba(204,255,0,0.1)" stroke="var(--lime)" stroke-width="1" opacity="0.5"/>
    <circle cx="150" cy="60" r="8" fill="rgba(204,255,0,0.1)" stroke="var(--lime)" stroke-width="1" opacity="0.5"/>
