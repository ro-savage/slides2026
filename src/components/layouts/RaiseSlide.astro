---
import { rich } from '../../lib/rich';

interface Props {
  eyebrow: string;
  title: string;
  raise: { amount: string; valuation: string };
  uses: { headline: string; label: string }[];
  footer: string;
}

const { eyebrow, title, raise, uses, footer } = Astro.props;
---
<div class="slide-inner">
  <div class="eyebrow">{eyebrow}</div>
  <h2 set:html={rich(title)} />
  <div class="raise-amount">
    <span class="raise-number">{raise.amount}</span>
    <span class="raise-valuation" set:html={rich(raise.valuation)} />
  </div>
  <div class="raise-uses">
    {uses.map((u) => (
      <div class="raise-use">
        <div class="use-headline" set:html={rich(u.headline)} />
        <div class="use-label" set:html={rich(u.label)} />
      </div>
    ))}
  </div>
  <div class="raise-footer" set:html={rich(footer)} />
</div>
