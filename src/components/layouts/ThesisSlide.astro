---
import { rich } from '../../lib/rich';

interface Step {
  heading: string;
  body: string;
}

interface Props {
  eyebrow: string;
  title: string;
  hypothesis: string;
  steps: Step[];
}

const { eyebrow, title, hypothesis, steps } = Astro.props;
---
<div class="slide-inner">
  <div class="eyebrow">{eyebrow}</div>
  <h2 set:html={rich(title)} />
  <div class="thesis-hypothesis">
    <div class="hypothesis-tag">HYPOTHESIS</div>
    <div class="hypothesis-body" set:html={rich(hypothesis)} />
  </div>
  <div class="thesis-proof">
    {steps.map((step, i) => (
      <div class="thesis-step">
        <div class="thesis-heading" set:html={rich(step.heading)} />
        <div class="thesis-text" set:html={rich(step.body)} />
      </div>
    ))}
  </div>
</div>
