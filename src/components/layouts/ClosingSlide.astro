---
import { rich } from '../../lib/rich';
import GrowthLine from '../decorations/GrowthLine.astro';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  body?: string;
  cta?: { label: string; href: string };
  decoration?: string;
}

const { eyebrow, title, subtitle, body, cta, decoration } = Astro.props;
---
<div class="slide-inner" style="text-align:center">
  <div class="eyebrow">{eyebrow}</div>
  <h1 set:html={rich(title)} />
  {subtitle && <p class="subtitle" style="margin:0 auto 24px" set:html={rich(subtitle)} />}
  {body && (
    <div style="opacity:0;transform:translateY(20px)" class="reveal-on-active">
      <p
        style="font-size:clamp(16px,1.8vw,24px);color:var(--text);line-height:1.6;max-width:740px;margin:0 auto;font-weight:300"
        set:html={rich(body)}
      />
    </div>
  )}
  {cta && (
    <div class="cta-block">
      <a href={cta.href} target="_blank" rel="noopener" class="cta-btn">{cta.label}</a>
    </div>
  )}
  {decoration === 'growth-line' && <GrowthLine />}
</div>
