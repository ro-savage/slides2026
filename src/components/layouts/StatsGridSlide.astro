---
import { rich } from '../../lib/rich';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  stats: { value: string; label: string }[];
  tags?: string[];
}

const { eyebrow, title, subtitle, stats, tags } = Astro.props;
---
<div class="slide-inner">
  <div class="eyebrow">{eyebrow}</div>
  <h2 set:html={rich(title)} />
  {subtitle && <p class="subtitle" set:html={rich(subtitle)} />}
  <div class="stat-grid">
    {stats.map((s) => (
      <div class="stat-card">
        <div class="stat-val">{s.value}</div>
        <div class="stat-label">{s.label}</div>
      </div>
    ))}
  </div>
  {tags && tags.length > 0 && (
    <div style="margin-top:32px;display:flex;flex-wrap:wrap;gap:12px;opacity:0;transform:translateY(10px)" class="reveal-on-active">
      {tags.map((t) => <span class="tag-pill">{t}</span>)}
    </div>
  )}
</div>
