---
import { rich } from '../../lib/rich';
import Barrier from '../decorations/Barrier.astro';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  bullets: string[];
  decoration?: string;
}

const { eyebrow, title, subtitle, bullets, decoration } = Astro.props;
---
<div class="slide-inner">
  <div class="eyebrow">{eyebrow}</div>
  <h2 set:html={rich(title)} />
  {subtitle && <p class="subtitle" set:html={rich(subtitle)} />}
  <div class="two-col" style="margin-top:32px">
    <div>
      <ul class="bullet-list">
        {bullets.map((b) => <li set:html={rich(b)} />)}
      </ul>
    </div>
    <div class="col-visual">
      {decoration === 'barrier' && <Barrier />}
    </div>
  </div>
</div>
