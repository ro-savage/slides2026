---
import { rich } from '../../lib/rich';
import NetworkGraph from '../decorations/NetworkGraph.astro';

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  effects: { headline: string; body?: string; tone: 'lime' | 'teal' }[];
  decoration?: string;
}

const { eyebrow, title, subtitle, effects, decoration } = Astro.props;

const HEADLINE_STYLE = {
  lime: 'font-size:clamp(20px,2vw,28px);font-weight:500;color:var(--lime);letter-spacing:-0.01em;line-height:1.2',
  teal: 'font-size:clamp(20px,2vw,28px);font-weight:500;color:var(--teal-light);letter-spacing:-0.01em;line-height:1.2',
} as const;
---
<div class="slide-inner">
  <div class="eyebrow">{eyebrow}</div>
  <h2 set:html={rich(title)} />
  {subtitle && <p class="subtitle" style="margin-bottom:8px" set:html={rich(subtitle)} />}
  <div class="two-col" style="margin-top:28px">
    <div>
      {effects.map((e, i) => (
        <div
          style={`${i > 0 ? 'margin-top:28px;' : ''}opacity:0;transform:translateY(20px)`}
          class="reveal-on-active"
          data-delay={i * 300}
        >
          <div style={HEADLINE_STYLE[e.tone]} set:html={rich(e.headline)} />
          {e.body && <div style="font-size:clamp(14px,1.4vw,18px);color:var(--text-dim);margin-top:8px;line-height:1.5" set:html={rich(e.body)} />}
        </div>
      ))}
    </div>
    <div class="col-visual">
      {decoration === 'network' && <NetworkGraph />}
    </div>
  </div>
</div>
