---
import { getCollection } from 'astro:content';
import Slide from '../components/Slide.astro';
import '../styles/deck.css';

const slides = (await getCollection('slides')).sort((a, b) => a.id.localeCompare(b.id));
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scannable — SmartPPE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Outfit:wght@200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="progress" id="progress"></div>

    <img
      src="https://cdn.prod.website-files.com/67e921c58f055d596a9ac2c3/68806162fed15b7bc7c34b81_Scannable%20Preferred%20Light.svg"
      alt="Scannable"
      class="logo"
    />

    <canvas id="bgCanvas"></canvas>

    <div class="deck" id="deck">
      {slides.map((slide, i) => <Slide index={i} data={slide.data} />)}
    </div>

    <div class="nav" id="nav"></div>
    <div class="slide-counter" id="slideCounter"></div>

    <script>
      (function () {
        const slides = document.querySelectorAll<HTMLElement>('.slide');
        const TOTAL = slides.length;
        let current = 0;
        let transitioning = false;
        const progress = document.getElementById('progress')!;
        const nav = document.getElementById('nav')!;
        const counter = document.getElementById('slideCounter')!;

        for (let i = 0; i < TOTAL; i++) {
          const dot = document.createElement('button');
          dot.className = 'nav-dot' + (i === 0 ? ' active' : '');
          dot.addEventListener('click', () => goTo(i));
          dot.setAttribute('aria-label', 'Slide ' + (i + 1));
          nav.appendChild(dot);
        }

        function updateUI() {
          progress.style.width = ((current + 1) / TOTAL) * 100 + '%';
          counter.textContent =
            String(current + 1).padStart(2, '0') + ' / ' + String(TOTAL).padStart(2, '0');
          nav.querySelectorAll('.nav-dot').forEach((d, i) => {
            d.classList.toggle('active', i === current);
          });
        }

        function goTo(idx: number) {
          if (idx === current || transitioning || idx < 0 || idx >= TOTAL) return;
          transitioning = true;
          const prev = slides[current];
          const next = slides[idx];
          const goingForward = idx > current;

          prev.classList.remove('active');
          prev.classList.add(goingForward ? 'exit-up' : 'exit-down');

          resetSlide(next);

          next.style.transition = 'none';
          next.style.transform = goingForward
            ? 'translateY(40px) scale(0.97)'
            : 'translateY(-40px) scale(0.97)';
          next.style.opacity = '0';

          void next.offsetHeight;

          next.style.transition = '';
          next.classList.add('active');
          next.style.transform = '';
          next.style.opacity = '';

          current = idx;
          updateUI();
          animateCounters(next);
          animateReveals(next);
          animateGrowthLine(next);

          setTimeout(() => {
            prev.classList.remove('exit-up', 'exit-down');
            resetSlide(prev);
            transitioning = false;
          }, 800);
        }

        function resetSlide(slide: HTMLElement) {
          slide.querySelectorAll<HTMLElement>('.counter').forEach((c) => {
            c.textContent = '0';
          });
          slide.querySelectorAll<HTMLElement>('.reveal-on-active').forEach((el) => {
            el.style.transition = 'none';
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
          });
          slide.querySelectorAll<HTMLElement>('.reveal-pop').forEach((el) => {
            el.style.transition = 'none';
            el.style.opacity = '0';
            el.style.transform = 'scale(0.9)';
          });
          const line = slide.querySelector<SVGPathElement>('.growth-line');
          if (line) {
            line.style.transition = 'none';
            line.style.strokeDashoffset = '1200';
          }
          slide.classList.remove('active');
          void slide.offsetHeight;
        }

        function animateCounters(slide: HTMLElement) {
          slide.querySelectorAll<HTMLElement>('.counter').forEach((el) => {
            const target = parseFloat(el.dataset.target!);
            const suffix = el.dataset.suffix || '';
            const duration = 1500;
            const start = performance.now();
            function tick(now: number) {
              const t = Math.min((now - start) / duration, 1);
              const ease = 1 - Math.pow(1 - t, 4);
              const val = (target * ease).toFixed(target % 1 === 0 ? 0 : 1);
              el.textContent = val + suffix;
              if (t < 1) requestAnimationFrame(tick);
            }
            setTimeout(() => requestAnimationFrame(tick), 500);
          });
        }

        function animateReveals(slide: HTMLElement) {
          slide.querySelectorAll<HTMLElement>('.reveal-on-active').forEach((el, i) => {
            const delay = parseInt(el.dataset.delay || '0') + i * 200 + 600;
            setTimeout(() => {
              el.style.transition = 'opacity 0.6s, transform 0.6s';
              el.style.opacity = '1';
              el.style.transform = 'translateY(0)';
            }, delay);
          });
          slide.querySelectorAll<HTMLElement>('.reveal-pop').forEach((el) => {
            setTimeout(() => {
              el.style.transition = 'opacity 0.7s, transform 0.7s cubic-bezier(.22,1,.36,1)';
              el.style.opacity = '1';
              el.style.transform = 'scale(1)';
            }, 1200);
          });
        }

        function animateGrowthLine(slide: HTMLElement) {
          const line = slide.querySelector<SVGPathElement>('.growth-line');
          if (!line) return;
          line.style.transition = 'none';
          line.style.strokeDashoffset = '1200';
          setTimeout(() => {
            line.style.transition = 'stroke-dashoffset 2s cubic-bezier(.22,1,.36,1)';
            line.style.strokeDashoffset = '0';
          }, 800);
        }

        updateUI();
        animateCounters(slides[0]);
        animateReveals(slides[0]);

        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') {
            e.preventDefault();
            goTo(current + 1);
          }
          if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault();
            goTo(current - 1);
          }
        });

        let touchStartY = 0;
        document.addEventListener(
          'touchstart',
          (e) => {
            touchStartY = e.touches[0].clientY;
          },
          { passive: true },
        );
        document.addEventListener('touchend', (e) => {
          const diff = touchStartY - e.changedTouches[0].clientY;
          if (Math.abs(diff) > 50) {
            diff > 0 ? goTo(current + 1) : goTo(current - 1);
          }
        });

        let wheelCooldown = false;
        document.addEventListener(
          'wheel',
          (e) => {
            if (wheelCooldown) return;
            wheelCooldown = true;
            if (e.deltaY > 30) goTo(current + 1);
            else if (e.deltaY < -30) goTo(current - 1);
            setTimeout(() => {
              wheelCooldown = false;
            }, 1200);
          },
          { passive: true },
        );

        const canvas = document.getElementById('bgCanvas') as HTMLCanvasElement;
        const ctx = canvas.getContext('2d')!;
        let W: number, H: number;
        const particles: Particle[] = [];
        const PARTICLE_COUNT = 80;

        function resize() {
          W = canvas.width = window.innerWidth;
          H = canvas.height = window.innerHeight;
        }
        resize();
        window.addEventListener('resize', resize);

        class Particle {
          x = 0;
          y = 0;
          vx = 0;
          vy = 0;
          r = 0;
          alpha = 0;
          constructor() {
            this.reset();
          }
          reset() {
            this.x = Math.random() * W;
            this.y = Math.random() * H;
            this.vx = (Math.random() - 0.5) * 0.3;
            this.vy = (Math.random() - 0.5) * 0.3;
            this.r = Math.random() * 1.5 + 0.5;
            this.alpha = Math.random() * 0.3 + 0.1;
          }
          update() {
            this.x += this.vx;
            this.y += this.vy;
            if (this.x < 0 || this.x > W) this.vx *= -1;
            if (this.y < 0 || this.y > H) this.vy *= -1;
          }
          draw() {
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(18,90,102,${this.alpha})`;
            ctx.fill();
          }
        }

        for (let i = 0; i < PARTICLE_COUNT; i++) particles.push(new Particle());

        function drawLines() {
          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const dist = Math.sqrt(dx * dx + dy * dy);
              if (dist < 150) {
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = `rgba(18,90,102,${0.08 * (1 - dist / 150)})`;
                ctx.lineWidth = 0.5;
                ctx.stroke();
              }
            }
          }
        }

        function animate() {
          ctx.clearRect(0, 0, W, H);
          particles.forEach((p) => {
            p.update();
            p.draw();
          });
          drawLines();
          requestAnimationFrame(animate);
        }
        animate();
      })();
    </script>
  </body>
</html>
